# ============================================================
# Plásticos NF — Environment variables
# Copy this file to .env.local for local development
# In production: set these in the Netlify dashboard
# (Site settings → Build & deploy → Environment → Environment variables)
# ============================================================

# Resend API key — get one at https://resend.com (free 3,000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where lead notifications arrive (your sales inbox)
LEAD_NOTIFICATION_EMAIL=ventas@plasticosnf.com

# Sender shown in the customer's auto-reply.
# IMPORTANT: must be on a domain verified in Resend.
# Before you verify your domain, use: onboarding@resend.dev
# After verifying plasticosnf.com, use: Plásticos NF <cotizaciones@plasticosnf.com>
EMAIL_FROM=Plásticos NF <onboarding@resend.dev>
